# =============================================================================
# 📁 [IDE & SYSTEM]
# =============================================================================
.idea/                  # PyCharm metadata
.vscode/                # VS Code metadata
*.swp                   # Vim swap files
.DS_Store               # macOS system files
vntest/                 # Temporary test directories
Thumbs.db               # Windows thumbnail cache
.nfs* # NFS recovery files (Important for debian mount)

# =============================================================================
# 🐍 [PYTHON & ENVIRONMENTS]
# =============================================================================
__pycache__/            # Compiled Python bytecode
*.py[cod]               # Python compiled files
.venv/                  # Virtual environment
venv/
env/                    #
ENV/
build/                  #
dist/                   #
*.egg-info/             #
.ipynb_checkpoints/     # Jupyter Notebook checkpoints
pip-log.txt
pip-delete-this-directory.txt
.coverage
coverage.xml

# =============================================================================
# 🔐 [SECRETS & CONFIGURATION]
# =============================================================================
.env                    # Never commit environment variables
config.toml             #
db_config.ini           #
*.toml                  # Broad ignore for config
*.ini                   # Broad ignore for config
*.pem                   # Private keys/Certificates
*.key                   # Private keys
auth.json               # Credential files

# =============================================================================
# 🤖 [AI & MACHINE LEARNING ASSETS]
# =============================================================================
# Logic: Never commit weights or raw data to source control.
models/                 # Local directory for Qwen-VL weights
checkpoints/            # Training/Fine-tuning snapshots
*.pth                   # PyTorch weights
*.bin                   # Model binaries
*.safetensors           # Modern weight format
*.onnx                  # Exported model graphs
*.pkl                   # Pickle files (often used for weights/data)

# =============================================================================
# 🖼️ [DATASETS & OUTPUTS]
# =============================================================================
data/                   # Training/Validation image sets
datasets/               #
images/                 #
videos/                 #
temp_results/           # Model inference previews
outputs/                # Saved logs, plots, or predictions
*.log                   # Application logs
qwen_v2d5/conversation/qwen-local-processor/

# Media Formats
*.jpg
*.JPG
*.png
*.ttf
*.avi
*.mov
*.mp4

# =============================================================================
# 🔍 [AUDIT & SECURITY]
# =============================================================================
bandit-report.txt       #
bandit-report.json      #
pip-audit-report.txt    #
.cache_ggshield         # Added by ggshield

# Added by ggshield
.cache_ggshield
__pycache__/
*.pyc

# === C++ Build Artifacts ===
# Ignore the entire build directory where CMake does its work
build/

# Ignore compiled shared libraries (the .so files Python imports)
*.so
*.pyd
*.dll
*.dylib

# Ignore object files and static libraries if they ever appear
*.o
*.obj
*.a
*.lib

# === CMake Generated Files (In case you run cmake in the root by accident) ===
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
Makefile
install_manifest.txt

# === IDE & OS specific ===
.cache/
.pypy/
.pydistutils.cfg

# --- VLM & Benchmarking Housekeeping ---
# SSD buffer for model weights (prevents 8GB RAM overflow)
offload_cache/

# Real-time VRAM telemetry logs from diagnostics
vram_audit.log

# Temporary tmux session artifacts (if any)
.tmux_history

# Byte-compiled C++ Engine artifacts (if not already covered)
*.so
build/
logs/
